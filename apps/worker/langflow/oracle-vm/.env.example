# Salin ke `.env` di folder ini (di VM, JANGAN commit ke repo) lalu isi.

LANGFLOW_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
LANGFLOW_AUTO_LOGIN=false
LANGFLOW_SUPERUSER=admin
LANGFLOW_SUPERUSER_PASSWORD=ganti-dengan-password-kuat
LANGFLOW_SECRET_KEY=ganti-dengan-string-acak

# Dibaca oleh 6 tool component lewat os.getenv(...) — lihat ../README.md.
WORKER_BASE_URL=https://komik-tracker-worker.<subdomain>.workers.dev
INTERNAL_TOOLS_SECRET=sama-persis-dengan-punya-worker
