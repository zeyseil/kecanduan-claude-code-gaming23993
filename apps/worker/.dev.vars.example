# Salin file ini ke `.dev.vars` (gitignored) lalu isi dengan kredensial Astra DB
# milikmu sendiri. Ambil dari Astra Console: astra.datastax.com -> pilih
# database -> tab "Connect" untuk API endpoint, dan "Generate Token" untuk
# application token.

ASTRA_DB_API_ENDPOINT=https://<database-id>-<region>.apps.astra.datastax.com
ASTRA_DB_APPLICATION_TOKEN=AstraCS:xxxxxxxx
ASTRA_DB_COLLECTION=comics
