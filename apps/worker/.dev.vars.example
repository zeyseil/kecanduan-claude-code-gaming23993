# Salin file ini ke `.dev.vars` (gitignored) lalu isi dengan kredensial Astra DB
# milikmu sendiri. Ambil dari Astra Console: astra.datastax.com -> pilih
# database -> tab "Connect" untuk API endpoint, dan "Generate Token" untuk
# application token.

ASTRA_DB_API_ENDPOINT=https://<database-id>-<region>.apps.astra.datastax.com
ASTRA_DB_APPLICATION_TOKEN=AstraCS:xxxxxxxx
ASTRA_DB_COLLECTION=comics

# Collection Astra terpisah untuk audit trail (SPEC.md §9) — dibuat via
# `pnpm --filter worker run create-collection`.
PROCESS_LOG_COLLECTION=process_log

# Secret statis yang harus dikirim tiap request ke /internal/tools/* lewat
# header X-Internal-Secret. Isi dengan string acak sendiri (mis. `openssl rand
# -hex 32`) — nilai yang sama harus dikonfigurasi di tiap Tool component
# Langflow (tweaks, bukan diisi LLM).
INTERNAL_TOOLS_SECRET=ganti-dengan-secret-acak-mu

# Endpoint /run instance Langflow-mu (dari DataStax Langflow atau self-hosted)
# dan API key untuk autentikasi ke Langflow itu sendiri — beda dari
# google_api_key milik user yang dikirim per-request.
LANGFLOW_API_URL=https://<langflow-host>/api/v1/run/<flow-id>
LANGFLOW_API_KEY=xxxxxxxx
