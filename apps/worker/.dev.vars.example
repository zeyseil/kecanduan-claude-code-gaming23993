# Salin file ini ke `.dev.vars` (gitignored) lalu isi dengan kredensial Astra DB
# milikmu sendiri. Ambil dari Astra Console: astra.datastax.com -> pilih
# database -> tab "Connect" untuk API endpoint, dan "Generate Token" untuk
# application token.

ASTRA_DB_API_ENDPOINT=https://<database-id>-<region>.apps.astra.datastax.com
ASTRA_DB_APPLICATION_TOKEN=AstraCS:xxxxxxxx
ASTRA_DB_COLLECTION=comics

# Collection Astra terpisah untuk audit trail (SPEC.md §9) — dibuat via
# `pnpm --filter worker run create-collection`.
PROCESS_LOG_COLLECTION=process_log

# (Opsional) Override model Gemini yang dipakai AI agent. Kalau dikosongkan,
# Worker memakai default di src/agent/geminiClient.ts. Isi kalau Google
# mengganti/menghentikan nama model itu, atau kalau mau coba model lain.
# GEMINI_MODEL=gemini-3.5-flash

# (Opsional) Sumber cover tambahan.
#   comick.io: sumber BAWAAN (dipanggil langsung dari Worker, nol setup) —
#              dicoba setelah MangaDex, sebelum AniList. Set COMICK_API_URL HANYA
#              kalau mau override base URL default (https://api.comick.dev), mis.
#              kalau comick pindah domain lagi atau kamu pakai proxy sendiri.
#   KOMIKU_API_URL: base URL instance Komiku REST API (VernSG), dicoba terakhir.
#                   Dilewati diam-diam kalau dikosongkan. Sengaja TIDAK di-default
#                   otomatis (tidak mau diam-diam membebani instance publik orang
#                   lain) — isi sendiri kalau mau pakai:
#                     - Instance publik proyeknya (dicek live, shared/gratis, bisa
#                       lambat/down kapan saja): https://komiku-rest-api.vercel.app
#                     - Atau deploy instance sendiri (lihat README bagian
#                       "Sumber cover tambahan").
# COMICK_API_URL=
# KOMIKU_API_URL=

# (Opsional) Override base URL Kiryuu (sumber "Cari link chapter berikutnya",
# bahasa Indonesia, fokus manga). Kosong = default https://v7.kiryuu.to. Isi
# kalau Kiryuu pindah versi domain (situs ini beberapa kali ganti, mis. v7).
# KIRYUU_API_URL=

# CATATAN: tidak ada secret Langflow di sini lagi. Orkestrasi AI sekarang jalan
# di dalam Worker (src/agent/), memanggil Gemini langsung dengan API key milik
# user yang dikirim per-request — tidak pernah disimpan di server.
