{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "komik-tracker",
  "version": "0.1.0",
  "identifier": "com.zeyseil.komik-tracker",
  "build": {
    "frontendDist": "../apps/web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter web dev:tauri",
    "beforeBuildCommand": "pnpm --filter web build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "Komik Tracker",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
